﻿<!DOCTYPE html>
<html lang="uk" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — StudyHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&amp;family=Inter:wght@300;400;500;600&amp;display=swap" rel="stylesheet" />
    <style>
        :root {
            --orange-primary: #FF6B1A;
            --orange-light:   #FF8C42;
            --orange-dim:     #CC5200;
            --orange-glow:    rgba(255, 107, 26, 0.18);
            --orange-glow-sm: rgba(255, 107, 26, 0.08);
            --bg-base:        #0A0A0A;
            --bg-card:        #111111;
            --bg-card2:       #161616;
            --border-subtle:  rgba(255, 107, 26, 0.15);
            --border-card:    rgba(255, 255, 255, 0.06);
            --text-primary:   #F5F0EB;
            --text-muted:     #7A7268;
            --text-secondary: #B8AFA8;
            --gradient-hero:  linear-gradient(135deg, #0A0A0A 0%, #1A0D05 50%, #0A0A0A 100%);
            --gradient-orange: linear-gradient(135deg, #FF6B1A, #FF8C42);
            --gradient-card:  linear-gradient(145deg, #161616, #111111);
            --shadow-card:    0 4px 24px rgba(0,0,0,0.5);
            --font-display:   'Syne', sans-serif;
            --font-body:      'Inter', sans-serif;
            --radius-card:    16px;
        }
        * { box-sizing: border-box; }
        body {
            font-family: var(--font-body);
            background: var(--bg-base);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            font-size: 15px;
            line-height: 1.65;
        }
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 0;
            opacity: .6;
        }
        main { flex: 1; position: relative; z-index: 1; }
        h1,h2,h3,h4,h5,h6 { font-family: var(--font-display); font-weight: 700; }

        /* NAVBAR */
        .navbar-studyhub {
            background: rgba(10,10,10,0.88);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-subtle);
            padding: 0.6rem 0;
            position: sticky; top: 0; z-index: 1030;
            transition: box-shadow 0.3s ease;
        }
        .navbar-studyhub.scrolled {
            box-shadow: 0 2px 32px rgba(0,0,0,0.6), 0 0 20px var(--orange-glow);
        }
        .navbar-brand-logo {
            font-family: var(--font-display);
            font-size: 1.5rem; font-weight: 800; letter-spacing: -0.5px;
            color: var(--text-primary) !important;
            text-decoration: none;
            display: flex; align-items: center; gap: 10px;
        }
        .logo-icon {
            width: 36px; height: 36px;
            background: var(--gradient-orange);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; color: #fff;
            box-shadow: 0 0 16px rgba(255,107,26,0.4);
        }
        .logo-text span { color: var(--orange-primary); }
        .nav-link-custom {
            color: var(--text-secondary) !important;
            font-size: 0.875rem; font-weight: 500;
            padding: 0.5rem 0.85rem !important;
            border-radius: 8px;
            transition: all 0.2s ease;
            display: flex; align-items: center; gap: 6px;
            text-decoration: none;
        }
        .nav-link-custom:hover, .nav-link-custom.active {
            color: var(--orange-light) !important;
            background: var(--orange-glow-sm);
        }
        .badge-queue {
            background: var(--orange-primary); color: #fff;
            font-size: 0.65rem; padding: 2px 6px; border-radius: 20px; font-weight: 700;
        }

        /* BUTTONS */
        .btn-orange {
            background: var(--gradient-orange); border: none; color: #fff;
            font-weight: 600; font-family: var(--font-display);
            border-radius: 10px; padding: 0.55rem 1.4rem;
            transition: all 0.25s ease;
            box-shadow: 0 4px 16px rgba(255,107,26,0.3);
            display: inline-flex; align-items: center; gap: 7px;
            cursor: pointer;
        }
        .btn-orange:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(255,107,26,0.45); color: #fff;
        }
        .btn-outline-orange {
            background: transparent; border: 1.5px solid var(--orange-primary);
            color: var(--orange-primary); font-weight: 600; font-family: var(--font-display);
            border-radius: 10px; padding: 0.5rem 1.4rem;
            transition: all 0.25s ease;
            display: inline-flex; align-items: center; gap: 7px;
        }
        .btn-outline-orange:hover {
            background: var(--orange-glow); border-color: var(--orange-light);
            color: var(--orange-light); transform: translateY(-1px);
        }
        .btn-ghost {
            background: rgba(255,255,255,0.05); border: 1px solid var(--border-card);
            color: var(--text-secondary); border-radius: 10px; padding: 0.5rem 1.2rem;
            font-weight: 500; transition: all 0.2s ease;
            display: inline-flex; align-items: center; gap: 7px;
            cursor: pointer; text-decoration: none;
        }
        .btn-ghost:hover {
            background: rgba(255,255,255,0.08); color: var(--text-primary);
            border-color: rgba(255,255,255,0.12);
        }

        /* FORM CONTROLS */
        .form-control-dark, .form-select-dark {
            background: rgba(255,255,255,0.04) !important;
            border: 1px solid var(--border-card) !important;
            color: var(--text-primary) !important;
            border-radius: 10px; padding: 0.6rem 1rem;
            font-family: var(--font-body); font-size: 0.9rem;
            transition: all 0.2s ease;
        }
        .form-control-dark:focus, .form-select-dark:focus {
            background: rgba(255,107,26,0.05) !important;
            border-color: var(--orange-primary) !important;
            box-shadow: 0 0 0 3px rgba(255,107,26,0.15) !important;
            outline: none; color: var(--text-primary) !important;
        }
        .form-control-dark::placeholder { color: var(--text-muted); }
        .form-select-dark option { background: #1a1a1a; color: var(--text-primary); }

        /* STATUS */
        .status-badge {
            font-size: 0.75rem; font-weight: 600;
            padding: 4px 12px; border-radius: 50px; letter-spacing: 0.3px;
            display: inline-flex; align-items: center; gap: 5px;
        }
        .status-pending  { background: rgba(255,193,7,0.12); color: #ffc107; border: 1px solid rgba(255,193,7,0.25); }
        .status-approved { background: rgba(34,197,94,0.1);  color: #22c55e; border: 1px solid rgba(34,197,94,0.2); }
        .status-rejected { background: rgba(239,68,68,0.1);  color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }

        /* SECTION LABEL */
        .section-label {
            font-size: 0.7rem; font-weight: 700; letter-spacing: 2px;
            text-transform: uppercase; color: var(--orange-primary);
            display: flex; align-items: center; gap: 8px;
        }
        .section-label::before {
            content: ''; display: block; width: 18px; height: 2px;
            background: var(--orange-primary); border-radius: 2px;
        }

        /* GLOW ORBs */
        .glow-orb { position: absolute; border-radius: 50%; filter: blur(90px); pointer-events: none; z-index: 0; }
        .glow-orb-1 {
            width: 400px; height: 400px;
            background: radial-gradient(circle, rgba(255,107,26,0.12), transparent 70%);
            top: -100px; left: -100px;
        }
        .glow-orb-2 {
            width: 300px; height: 300px;
            background: radial-gradient(circle, rgba(255,140,66,0.08), transparent 70%);
            bottom: 0; right: 10%;
        }

        /* USER AVATAR */
        .user-avatar {
            width: 34px; height: 34px;
            background: var(--gradient-orange);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.8rem; font-weight: 700; color: #fff;
            font-family: var(--font-display); flex-shrink: 0;
        }

        /* DROPDOWN */
        .dropdown-menu-dark-custom {
            background: #1a1a1a; border: 1px solid var(--border-subtle);
            border-radius: 12px; padding: 6px;
            box-shadow: 0 16px 40px rgba(0,0,0,0.6);
        }
        .dropdown-menu-dark-custom .dropdown-item {
            color: var(--text-secondary); border-radius: 8px;
            font-size: 0.875rem; padding: 0.5rem 0.8rem;
            display: flex; align-items: center; gap: 8px;
            transition: all 0.15s;
        }
        .dropdown-menu-dark-custom .dropdown-item:hover {
            background: var(--orange-glow-sm); color: var(--orange-light);
        }
        .dropdown-menu-dark-custom .dropdown-divider { border-color: var(--border-card); margin: 4px 0; }

        /* FOOTER */
        .footer-studyhub {
            background: var(--bg-card);
            border-top: 1px solid var(--border-subtle);
            padding: 2.5rem 0 1.5rem;
            margin-top: auto; position: relative; z-index: 1;
        }
        .footer-brand { font-family: var(--font-display); font-size: 1.2rem; font-weight: 800; color: var(--text-primary); }
        .footer-brand span { color: var(--orange-primary); }
        .footer-links a {
            color: var(--text-muted); text-decoration: none; font-size: 0.85rem;
            transition: color 0.2s; display: flex; align-items: center; gap: 6px;
        }
        .footer-links a:hover { color: var(--orange-light); }
        .footer-copy {
            color: var(--text-muted); font-size: 0.8rem;
            border-top: 1px solid var(--border-card);
            margin-top: 1.5rem; padding-top: 1rem;
        }

        /* ALERTS */
        .alert-studyhub {
            background: rgba(255,107,26,0.08); border: 1px solid rgba(255,107,26,0.2);
            color: var(--text-primary); border-radius: 12px; font-size: 0.9rem;
        }

        /* PAGINATION */
        .pagination .page-link {
            background: var(--bg-card); border-color: var(--border-card);
            color: var(--text-secondary); border-radius: 8px !important;
            margin: 0 2px; transition: all 0.2s;
        }
        .pagination .page-link:hover, .pagination .page-item.active .page-link {
            background: var(--orange-primary); border-color: var(--orange-primary); color: #fff;
        }

        /* SCROLLBAR */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-base); }
        ::-webkit-scrollbar-thumb { background: var(--orange-dim); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--orange-primary); }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-studyhub" id="mainNavbar">
    <div class="container">
        <a class="navbar-brand-logo" asp-controller="Home" asp-action="Index">
            <div class="logo-icon"><i class="bi bi-journal-richtext"></i></div>
            <div class="logo-text">Study<span>Hub</span></div>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                style="color:var(--orange-primary);">
            <i class="bi bi-list" style="font-size:1.4rem;"></i>
        </button>
        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto gap-1 mt-2 mt-lg-0">
                <li class="nav-item">
                    <a class="nav-link-custom" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house"></i> Головна
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link-custom" asp-controller="Notes" asp-action="Index">
                        <i class="bi bi-collection"></i> Конспекти
                    </a>
                </li>
                @if (User.IsInRole("student"))
                {
                    <li class="nav-item">
                        <a class="nav-link-custom" asp-controller="Notes" asp-action="MyNotes">
                            <i class="bi bi-person-lines-fill"></i> Мої конспекти
                        </a>
                    </li>
                }
                @if (User.IsInRole("moderator"))
                {
                    <li class="nav-item">
                        <a class="nav-link-custom" asp-controller="Moderation" asp-action="Queue">
                            <i class="bi bi-shield-check"></i> Модерація
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-custom" asp-controller="Moderation" asp-action="Stats">
                            <i class="bi bi-bar-chart-line"></i> Статистика
                        </a>
                    </li>
                }
            </ul>
            <div class="d-flex align-items-center gap-2 mt-2 mt-lg-0">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="dropdown">
                        <button class="btn-ghost dropdown-toggle d-flex align-items-center gap-2 border-0"
                                data-bs-toggle="dropdown" style="background:transparent;color:var(--text-secondary);">
                            <div class="user-avatar">
                                @(User.Identity.Name?.Substring(0,1).ToUpper() ?? "U")
                            </div>
                            <span class="d-none d-md-inline" style="font-size:.875rem;">@User.Identity.Name</span>
                            <i class="bi bi-chevron-down" style="font-size:.7rem;"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark-custom">
                            <li>
                                <a class="dropdown-item" asp-controller="Notes" asp-action="MyNotes">
                                    <i class="bi bi-person-circle"></i> Мій профіль
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" style="color:#ef4444;" asp-controller="Home" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i> Вийти
                                </a>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Home" asp-action="Login" class="btn-ghost">
                        <i class="bi bi-box-arrow-in-right"></i> Увійти
                    </a>
                    /*
                    <a asp-controller="Notes" asp-action="MyNotes" class="btn-orange" style="text-decoration:none;">
                        <i class="bi bi-person-plus"></i> Приєднатись
                    </a>
                    */
                }
            </div>
        </div>
    </div>
</nav>

<!-- ALERTS -->
@if (TempData["Success"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-studyhub d-flex align-items-center gap-2 alert-dismissible fade show">
            <i class="bi bi-check-circle-fill" style="color:#22c55e;"></i>
            @TempData["Success"]
            <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert"></button>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-studyhub d-flex align-items-center gap-2 alert-dismissible fade show"
             style="border-color:rgba(239,68,68,0.3);background:rgba(239,68,68,0.08);">
            <i class="bi bi-exclamation-triangle-fill" style="color:#ef4444;"></i>
            @TempData["Error"]
            <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<!-- MAIN -->
<main>@RenderBody()</main>

<!-- FOOTER -->
<footer class="footer-studyhub">
    <div class="container">
        <div class="row g-4 align-items-start">
            <div class="col-lg-4">
                <div class="footer-brand mb-2">Study<span>Hub</span></div>
                <p style="font-size:.85rem;color:var(--text-muted);max-width:280px;">
                    Платформа для обміну навчальними матеріалами між студентами.
                </p>
                <div class="d-flex gap-2 mt-3">
                    <a href="#" class="btn-ghost" style="padding:.4rem .7rem;font-size:.85rem;">
                        <i class="bi bi-github"></i>
                    </a>
                    <a href="#" class="btn-ghost" style="padding:.4rem .7rem;font-size:.85rem;">
                        <i class="bi bi-telegram"></i>
                    </a>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <div class="section-label mb-3">Навігація</div>
                <ul class="list-unstyled footer-links d-flex flex-column gap-2">
                    <li><a asp-controller="Home" asp-action="Index"><i class="bi bi-house"></i> Головна</a></li>
                    <li><a asp-controller="Notes" asp-action="Index"><i class="bi bi-collection"></i> Конспекти</a></li>
                </ul>
            </div>
            <div class="col-6 col-lg-2">
                <div class="section-label mb-3">Акаунт</div>
                <ul class="list-unstyled footer-links d-flex flex-column gap-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li><a asp-controller="Notes" asp-action="MyNotes"><i class="bi bi-person"></i> Профіль</a></li>
                        <li><a asp-controller="Auth" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> Вийти</a></li>
                    }
                    else
                    {
                        <li><a asp-controller="Auth" asp-action="Login"><i class="bi bi-box-arrow-in-right"></i> Увійти</a></li>
                    }
                </ul>
            </div>
            <div class="col-lg-4">
                <div class="section-label mb-3">Предмети</div>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var subj in new[] { "Програмування", "Математика", "Бази даних", "Мережі", "Англійська" })
                    {
                        <a href="/Notes?subject=@subj" style="text-decoration:none;">
                            <span style="background:var(--orange-glow-sm);border:1px solid var(--border-subtle);
                                         color:var(--text-muted);border-radius:50px;padding:3px 12px;
                                         font-size:.78rem;display:inline-block;">
                                @subj
                            </span>
                        </a>
                    }
                </div>
            </div>
        </div>
        <div class="footer-copy d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span>© 2025 StudyHub — усі права захищені.</span>
            <span style="display:flex;align-items:center;gap:6px;">
                <i class="bi bi-shield-lock" style="color:var(--orange-primary);"></i>
                Захищено Keycloak
            </span>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const navbar = document.getElementById('mainNavbar');
    window.addEventListener('scroll', () => navbar.classList.toggle('scrolled', window.scrollY > 20));
    document.querySelectorAll('.alert').forEach(el => {
        setTimeout(() => bootstrap.Alert.getOrCreateInstance(el)?.close(), 5000);
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>