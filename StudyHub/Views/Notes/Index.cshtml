@model IEnumerable<StudyHub.Models.Note>
@{
    ViewData["Title"] = "Конспекти";
    var subjects = ViewBag.Subjects as List<StudyHub.Models.Subject> ?? new();
    var selectedSubjectId = ViewBag.SelectedSubjectId as int?;
    var selectedCourse = ViewBag.SelectedCourse as int?;
    var topAuthors = ViewBag.TopAuthors as dynamic;
}

@section Styles {
<style>
    /* PAGE HEADER */
    .page-hero {
        background: var(--gradient-hero);
        padding: 3rem 0 2.5rem;
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid var(--border-subtle);
    }
    .page-hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 50% 40% at 50% 0%, rgba(255,107,26,0.15) 0%, transparent 70%);
        pointer-events: none;
    }
    .page-hero-content { position: relative; z-index: 2; }
    .page-breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 1rem;
    }
    .page-breadcrumb a {
        color: var(--orange-light);
        text-decoration: none;
    }
    .page-breadcrumb a:hover { text-decoration: underline; }
    .page-hero h1 {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 800;
        letter-spacing: -1px;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }
    .page-hero-subtitle {
        color: var(--text-muted);
        font-size: 1rem;
        max-width: 600px;
    }

    /* FILTER BAR */
    .filter-bar {
        background: var(--bg-card);
        border: 1px solid var(--border-card);
        border-radius: var(--radius-card);
        padding: 1.2rem 1.5rem;
        margin-bottom: 2rem;
    }
    .search-wrap { position: relative; }
    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 1rem;
        pointer-events: none;
    }
    .search-wrap .form-control-dark { padding-left: 2.6rem; }

    /* NOTE CARD */
    .note-card {
        background: var(--gradient-card);
        border: 1px solid var(--border-card);
        border-radius: var(--radius-card);
        padding: 1.4rem;
        transition: all .3s ease;
        display: flex;
        flex-direction: column;
        height: 100%;
        position: relative;
        overflow: hidden;
    }
    .note-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 3px;
        height: 100%;
        background: var(--gradient-orange);
        opacity: 0;
        transition: opacity .3s;
    }
    .note-card:hover {
        border-color: var(--border-subtle);
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 0 30px var(--orange-glow);
    }
    .note-card:hover::before { opacity: 1; }
    .note-subject-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--orange-glow-sm);
        border: 1px solid var(--border-subtle);
        color: var(--orange-light);
        font-size: 0.72rem;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 50px;
        letter-spacing: 0.3px;
        text-transform: uppercase;
    }
    .course-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: rgba(255,255,255,0.04);
        border: 1px solid var(--border-card);
        color: var(--text-muted);
        font-size: 0.72rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 50px;
    }
    .note-title {
        font-family: var(--font-display);
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0.8rem 0 0.5rem;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .note-preview {
        color: var(--text-muted);
        font-size: 0.85rem;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: auto;
    }
    .note-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 1.2rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border-card);
    }
    .note-author {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-secondary);
        font-size: 0.8rem;
        font-weight: 500;
    }
    .note-author-avatar {
        width: 26px;
        height: 26px;
        background: var(--gradient-orange);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.65rem;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
    }
    .like-count {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--text-muted);
    }

    /* SIDEBAR */
    .sidebar-widget {
        background: var(--gradient-card);
        border: 1px solid var(--border-card);
        border-radius: var(--radius-card);
        padding: 1.4rem;
        margin-bottom: 1.5rem;
    }
    .widget-title {
        font-family: var(--font-display);
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 1.1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .widget-title i { color: var(--orange-primary); }
    .subject-filter-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 0.7rem;
        border-radius: 9px;
        cursor: pointer;
        transition: all .2s;
        text-decoration: none;
        color: var(--text-secondary);
        font-size: 0.875rem;
        margin-bottom: 2px;
    }
    .subject-filter-item:hover,
    .subject-filter-item.active {
        background: var(--orange-glow-sm);
        color: var(--orange-light);
    }
    .subject-filter-item.active {
        border-left: 2px solid var(--orange-primary);
    }
    .subject-count {
        font-size: 0.75rem;
        background: rgba(255,255,255,0.06);
        border-radius: 50px;
        padding: 1px 8px;
        color: var(--text-muted);
    }
    .top-author-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0.6rem 0;
        border-bottom: 1px solid var(--border-card);
    }
    .top-author-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }
    .top-author-rank {
        width: 22px;
        font-family: var(--font-display);
        font-size: 0.8rem;
        font-weight: 800;
        color: var(--text-muted);
        flex-shrink: 0;
        text-align: center;
    }
    .top-author-rank.gold { color: #FFD700; }
    .top-author-rank.silver { color: #C0C0C0; }
    .top-author-rank.bronze { color: #CD7F32; }
    .top-author-name {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-primary);
        flex: 1;
    }
    .top-author-count {
        font-size: 0.78rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 4px;
    }

    /* EMPTY STATE */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
    }
    .empty-icon {
        width: 80px;
        height: 80px;
        background: var(--orange-glow-sm);
        border: 1px solid var(--border-subtle);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2rem;
        color: var(--orange-primary);
    }
    .empty-state h5 {
        color: var(--text-primary);
        font-family: var(--font-display);
        margin-bottom: .5rem;
    }
    .empty-state p {
        color: var(--text-muted);
        font-size: .9rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }
    .section-header h2 {
        font-size: 1.2rem;
        font-weight: 800;
        letter-spacing: -0.5px;
        color: var(--text-primary);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .section-header h2 i { color: var(--orange-primary); }
    .results-count {
        color: var(--text-muted);
        font-size: .85rem;
    }
    .results-count strong { color: var(--text-secondary); }
</style>
}

<!-- PAGE HERO -->
<section class="page-hero">
    <div class="container page-hero-content">
        <div class="page-breadcrumb">
            <a asp-controller="Home" asp-action="Index">
                <i class="bi bi-house"></i> Головна
            </a>
            <i class="bi bi-chevron-right"></i>
            <span>Конспекти</span>
        </div>
        <h1><i class="bi bi-collection-fill" style="color:var(--orange-primary);"></i> Усі конспекти</h1>
        <p class="page-hero-subtitle">
            Переглядай, фільтруй та знаходь найкращі навчальні матеріали від студентів
        </p>
    </div>
</section>

<!-- MAIN CONTENT -->
<div class="container" style="padding-top:2.5rem;padding-bottom:3rem;">
    <div class="row g-4">
        <!-- Left: Notes -->
        <div class="col-lg-8">
            <!-- Filter bar -->
            <div class="filter-bar">
                <form method="get" asp-action="Index">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-5">
                            <div class="search-wrap">
                                <i class="bi bi-search search-icon"></i>
                                <input type="text" name="search" class="form-control-dark" placeholder="Пошук конспектів..." />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <select name="subject" class="form-select form-select-dark form-control-dark">
                                <option value="">Всі предмети</option>
                                @foreach (var s in subjects)
                                {
                                    <option value="@s.Id" selected="@(selectedSubjectId == s.Id ? "selected" : null)">@s.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <select name="course" class="form-select form-select-dark form-control-dark">
                                <option value="">Курс</option>
                                @for (int i = 1; i <= 4; i++)
                                {
                                    <option value="@i" selected="@(selectedCourse == i ? "selected" : null)">@i курс</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn-orange w-100" style="justify-content:center;">
                                <i class="bi bi-funnel"></i> Фільтр
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Section header -->
            <div class="section-header">
                <h2><i class="bi bi-grid-3x3-gap-fill"></i> Результати</h2>
                <div class="d-flex align-items-center gap-3">
                    @if (Model != null)
                    {
                        <span class="results-count">
                            Знайдено: <strong>@Model.Count()</strong>
                        </span>
                    }
                    @if (User.IsInRole("student"))
                    {
                        <a asp-controller="Notes" asp-action="Create" class="btn-orange"
                           style="text-decoration:none;">
                            <i class="bi bi-plus-lg"></i> Додати
                        </a>
                    }
                </div>
            </div>

            <!-- Grid -->
            @if (Model != null && Model.Any())
            {
                <div class="row g-3">
                    @foreach (var note in Model)
                    {
                        <div class="col-sm-6">
                            <a asp-controller="Notes" asp-action="Details" asp-route-id="@note.Id"
                               style="text-decoration:none;display:block;height:100%;">
                                <div class="note-card">
                                    <div class="d-flex flex-wrap gap-2 mb-1">
                                        <span class="note-subject-chip">
                                            <i class="bi bi-bookmark-fill"></i> @note.Subject?.Name
                                        </span>
                                        <span class="course-chip">
                                            <i class="bi bi-mortarboard"></i> @note.Course курс
                                        </span>
                                    </div>
                                    <div class="note-title">@note.Title</div>
                                    <div class="note-preview">@note.Content</div>
                                    <div class="note-footer">
                                        <div class="note-author">
                                            <div class="note-author-avatar">
                                                @(note.AuthorName?.Substring(0,1).ToUpper() ?? "A")
                                            </div>
                                            @note.AuthorName
                                            <span style="color:var(--text-muted);">·</span>
                                            <span style="color:var(--text-muted);">
                                                @note.CreatedAt.ToString("dd.MM.yy")
                                            </span>
                                        </div>
                                        <div class="like-count">
                                            <i class="bi bi-heart"></i> @note.LikesCount
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="bi bi-journal-x"></i></div>
                    <h5>Нічого не знайдено</h5>
                    <p>Спробуйте змінити фільтри або будьте першим, хто додасть конспект!</p>
                    @if (User.IsInRole("student"))
                    {
                        <a asp-controller="Notes" asp-action="Create" class="btn-orange mt-2" style="text-decoration:none;">
                            <i class="bi bi-plus-lg"></i> Додати конспект
                        </a>
                    }
                </div>
            }
        </div>

        <!-- Right: Sidebar -->
        <div class="col-lg-4">
            <!-- Top authors -->
            <div class="sidebar-widget">
                <div class="widget-title"><i class="bi bi-trophy-fill"></i> Топ автори</div>
                @if (topAuthors != null && ((IEnumerable<dynamic>)topAuthors).Any())
                {
                    int rank = 0;
                    @foreach (var author in topAuthors)
                    {
                        rank++;
                        string rankClass = rank == 1 ? "gold" : rank == 2 ? "silver" : "bronze";
                        <div class="top-author-item">
                            <div class="top-author-rank @rankClass">#@rank</div>
                            <div class="note-author-avatar" style="width:30px;height:30px;font-size:.7rem;">
                                @(author.AuthorName?.Substring(0,1).ToUpper() ?? "A")
                            </div>
                            <div class="top-author-name">@author.AuthorName</div>
                            <div class="top-author-count">
                                <i class="bi bi-file-text"></i> @author.NoteCount
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p style="color:var(--text-muted);font-size:.85rem;">Ще немає авторів.</p>
                }
            </div>

            <!-- Subjects -->
            <div class="sidebar-widget">
                <div class="widget-title"><i class="bi bi-tag-fill"></i> Предмети</div>
                <a asp-action="Index" class="subject-filter-item @(selectedSubjectId == null ? "active" : "")">
                    <span><i class="bi bi-grid me-1"></i> Всі предмети</span>
                </a>
                @foreach (var s in subjects)
                {
                    <a asp-action="Index" asp-route-subject="@s.Id" 
                       class="subject-filter-item @(selectedSubjectId == s.Id ? "active" : "")">
                        <span>@s.Name</span>
                    </a>
                }
            </div>

            <!-- Courses -->
            <div class="sidebar-widget">
                <div class="widget-title"><i class="bi bi-mortarboard-fill"></i> По курсах</div>
                @for (int c = 1; c <= 4; c++)
                {
                    <a asp-action="Index" asp-route-course="@c" 
                       class="subject-filter-item @(selectedCourse == c ? "active" : "")">
                        <span>@c курс</span>
                    </a>
                }
            </div>

            <!-- CTA for guests -->
            @if (!(User.Identity?.IsAuthenticated ?? false))
            {
                <div class="sidebar-widget" style="background:linear-gradient(135deg,rgba(255,107,26,0.12),rgba(255,140,66,0.06));
                     border-color:var(--border-subtle);text-align:center;">
                    <i class="bi bi-journal-richtext" style="font-size:2rem;color:var(--orange-primary);display:block;margin-bottom:.8rem;"></i>
                    <div style="font-family:var(--font-display);font-weight:700;margin-bottom:.5rem;">Маєш конспект?</div>
                    <p style="color:var(--text-muted);font-size:.83rem;margin-bottom:1rem;">
                        Увійди та поділись своїми матеріалами зі спільнотою
                    </p>
                    <a asp-controller="Home" asp-action="Login" class="btn-orange"
                       style="text-decoration:none;width:100%;justify-content:center;display:flex;">
                        <i class="bi bi-plus-lg"></i> Поділитись конспектом
                    </a>
                </div>
            }
            else if (User.IsInRole("student"))
            {
                <div class="sidebar-widget" style="background:linear-gradient(135deg,rgba(255,107,26,0.12),rgba(255,140,66,0.06));
         border-color:var(--border-subtle);text-align:center;">
                    <i class="bi bi-journal-richtext" style="font-size:2rem;color:var(--orange-primary);display:block;margin-bottom:.8rem;"></i>
                    <div style="font-family:var(--font-display);font-weight:700;margin-bottom:.5rem;">Мої конспекти</div>
                    <div class="d-flex flex-column gap-2">
                        <a asp-controller="Notes" asp-action="MyNotes" class="btn-orange"
                           style="text-decoration:none;width:100%;justify-content:center;display:flex;">
                            <i class="bi bi-person-lines-fill"></i> Мої конспекти
                        </a>
                        <a asp-controller="Notes" asp-action="Create" class="btn-ghost"
                           style="text-decoration:none;width:100%;justify-content:center;display:flex;">
                            <i class="bi bi-plus-lg"></i> Додати конспект
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>